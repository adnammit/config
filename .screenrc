
autodetach on
vbell on
defscrollback 10000
vbell on
startup_message off
shelltitle "$ |bash"


#HARDSTATUS:
hardstatus on
hardstatus string "%w%=%m/%d %c"
hardstatus alwayslastline "%{wk}%H%{wk}|%?%-Lw%?%{wb}%n*%f %t%?(%u)%?%{wk}%?%+Lw%?"



