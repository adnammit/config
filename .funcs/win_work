if [[ $OSTYPE == "cygwin" && $WORK_ENV ]] ; then

    function hello()
    {
        # Open our helper local window right below the first one:
        # mnt $COL1_X $ROW2_Y
        mnt -967 558
        open_editors
        # dcub
    }

    function dcu()
    {
        local a=$PWD
        cd '/cygdrive/c/dev/impactReports/integration'
        docker-compose up --detach
        cd ${a}
    }

    function dcub()
    {
        local a=$PWD
        cd '/cygdrive/c/dev/impactReports/integration'
        docker-compose up --detach --build
        cd ${a}
    }

    function dcd()
    {
        local a=$PWD
        cd '/cygdrive/c/dev/impactReports/integration'
        docker-compose down --remove-orphans
        cd ${a}
    }

    function dcdv()
    {
        local a=$PWD
        cd '/cygdrive/c/dev/impactReports/integration'
        docker-compose down -v --remove-orphans
        cd ${a}
    }

    function sopen()
    {
        if [[ ${1} ]] ; then

            local a=$PWD
            local SLN=${1}
            local MONSTER="C:/dev/CCI.Monster/src/"

            case "$SLN" in
                cm | intranet)
                    cd "${MONSTER}"
                    SLN="WebUI.Intranet.sln"
                    ;;
                rp | rateplan)
                    cd "${MONSTER}Billing/CCI.Billing.RatePlanService/"
                    SLN="CCI.Billing.RatePlanService.sln"
                    ;;
                orq)
                    cd "${MONSTER}CCI.Services/ConsumerCellularOrderReviewService/"
                    SLN="ConsumerCellularOrderReviewService.sln"
                    ;;
            esac

            if [ -e ${SLN} ] ; then
                explorer.exe "${SLN}"
            else
                echo "Can't find sln file ${SLN}"
            fi

            cd ${a}

        else

            shopt -s globstar
            local SLNS=(*.sln)

            if [ "${#SLNS[@]}" -gt 1 ] ; then
                echo "Found ${#SLNS[@]} sln files -- which one?"
            elif [ -e ${SLNS[0]} ] ; then
                explorer.exe ${SLNS[0]}
            else
                echo "No sln files found"
            fi
        fi
    }

fi
