
#GENERAL ALIASES:

alias grep='grep -n --color=auto'
alias rm='rm -i'
alias mv='mv -i'

# REFRESH AFTER MAKING CHANGES
alias rp='. ~/.bash_profile'

# BC SPELLIGN IS HARD
