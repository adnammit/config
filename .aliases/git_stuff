# GIT STUFF THAT DOESN'T WORK IN .GITCONFIG


# GREP IGNORE GIT STUFF
alias gr='grep -r -n --color=auto --exclude-dir=.git'

# USE GIT GREP TO SEARCH, EXCLUDE BINARIES (-I), DON'T LOOK AT BRANCH STUFF AND SEARCH UNTRACKED FILES.
alias grit='git grep -I --untracked --no-exclude-standard -- '

